KICK_STREAM_URL=rtmps://fa723a138bde.global-contribute.live-video.net:443/app/
# Optional: set if you don't use KICK_STREAM_URL; otherwise host is derived from URL
# KICK_STREAM_HOST=fa723a138bde.global-contribute.live-video.net
KICK_STREAM_KEY=sk_us_xxxxxxxxxxxxxxxx
FALLBACK_VIDEO=/assets/fallback.mp4
# Gaming (movimientos bruscos): bitrate alto, GOP bajo, preset veryfast para mejor calidad
FFMPEG_PRESET=veryfast
FFMPEG_BITRATE=10000k
FFMPEG_BUFSIZE=20000k
GOP_SIZE=15
STREAM_KEY=stream
# Buffer UDP: más alto = menos caídas en movimientos bruscos (default 5M). 10M si sigue glitcheando.
UDP_FIFO_SIZE=5000000
# Framerate de salida: debe coincidir con OBS (60 para gaming, 30 para ahorrar ancho de banda)
STREAM_FPS=60
# Debounce: segundos de espera antes de fallback cuando OBS desconecta (evita cortes si reconecta rápido)
FALLBACK_DELAY=0.5
